{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PAIV Manifest",
  "type": "object",
  "required": ["paiv_version", "layers"],
  "properties": {
    "paiv_version": {
      "type": "string",
      "description": "协议版本，如 V1.0"
    },
    "export_timestamp": {
      "type": "string",
      "description": "ISO 8601 格式的时间戳"
    },
    "layers": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["L00_Identity", "L01_Knowledge", "L02_Persona", "L03_Context", "L04_Secrets", "L05_Action"]
      }
    }
  }
}
