{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PAIV Identity (L00)",
  "type": "object",
  "required": ["identifier"],
  "properties": {
    "identifier": {
      "type": "object",
      "required": ["human_name"],
      "properties": {
        "human_name": {
          "type": "string",
          "description": "用户的法定姓名或主要称呼"
        },
        "preferred_call": {
          "type": "string",
          "description": "用户希望被 AI 称呼的方式"
        },
        "timezone": {
          "type": "string"
        },
        "language": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "core_values": {
      "type": "array",
      "description": "用户的核心价值观标签",
      "items": { "type": "string" }
    }
  }
}
