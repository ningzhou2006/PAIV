{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PAIV Secrets (L04)",
  "type": "object",
  "required": ["encryption"],
  "properties": {
    "encryption": {
      "type": "object",
      "required": ["algorithm"],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": ["AES-256-GCM", "ChaCha20-Poly1305"]
        },
        "encrypted_at": { "type": "string" }
      }
    },
    "secrets_reference": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "category": { "type": "string", "enum": ["api_key", "password", "token"] },
          "service": { "type": "string" }
        }
      }
    }
  }
}
